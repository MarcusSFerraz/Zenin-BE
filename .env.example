# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=zenin
DB_USER=postgres
DB_PASSWORD=your_password_here

# Servidor
SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=prod

# JWT — gere com: openssl rand -hex 32
JWT_SECRET=your_hex_secret_here
JWT_EXPIRATION_MS=86400000

# CORS — origins permitidas (separe por vírgula para múltiplos)
APP_CORS_ALLOWED_ORIGINS=https://seudominio.com

# Upload
UPLOAD_DIR=uploads
BASE_URL=https://seudominio.com
